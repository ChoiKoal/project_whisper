; Engine configuration file.
; Project Whisper — M0/M1
; Godot 4.5

config_version=5

[application]

config/name="Project Whisper"
config/version="0.2.1"
run/main_scene="res://scenes/ui/title.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")

[autoload]

GameState="*res://scripts/core/game_state.gd"
ItemDB="*res://scripts/core/item_db.gd"
Inventory="*res://scripts/core/inventory.gd"
RecipeDB="*res://scripts/core/recipe_db.gd"
Codex="*res://scripts/core/codex.gd"
Fusion="*res://scripts/core/fusion.gd"
SaveManager="*res://scripts/core/save_manager.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/size/resizable=true
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

